# SERVER CONFIGURATION
PORT=3000
NODE_ENV=development

# SUPABASE CONFIGURATION
SUPABASE_URL=your-project-url
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# RETELL AI CONFIGURATION
RETELL_API_KEY=your-retell-api-key
RETELL_DEMO_AGENT_ID=your-demo-agent-id

# GOOGLE CALENDAR CONFIGURATION
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REFRESH_TOKEN=your-google-refresh-token
GOOGLE_CALENDAR_ID=primary

# GOOGLE SHEETS CONFIGURATION (CALLING DASHBOARD)
GOOGLE_SHEETS_CLIENT_EMAIL=your-sheets-service-account-email
GOOGLE_SHEETS_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your-google-sheet-id

# WEBHOOK CONFIGURATIONS (n8n)
N8N_WEBHOOK_URL=your-n8n-webhook-url
N8N_WEBSITE_WEBHOOK_URL=your-n8n-website-webhook-url
N8N_OUTBOUND_WEBHOOK_URL=your-n8n-outbound-webhook-url

# FRONTEND CONFIGURATION (for reset password links)
APP_URL=https://lunostudios.ca
